{
  "version": 2,
  "name": "echoscribe-voice-transcriber",
  "builds": [
    {
      "src": "vercel_app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel_app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "PYTHONPATH": "."
  },
  "functions": {
    "vercel_app.py": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"],
  "framework": "flask"
}
